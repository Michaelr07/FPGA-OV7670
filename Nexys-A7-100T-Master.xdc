set_property -dict {PACKAGE_PIN J13 IOSTANDARD LVCMOS33} [get_ports {STATE[1]}]
set_property -dict {PACKAGE_PIN N14 IOSTANDARD LVCMOS33} [get_ports {STATE[2]}]
