set_property -dict {PACKAGE_PIN G13 IOSTANDARD LVCMOS33} [get_ports CAM_SCL]
set_property -dict {PACKAGE_PIN H16 IOSTANDARD LVCMOS33} [get_ports CAM_PCLK]


