set_property -dict {PACKAGE_PIN P18 IOSTANDARD LVCMOS33} [get_ports CTRL_BTN]


##Pmod Headers


##Pmod Header JA

set_property -dict {PACKAGE_PIN C17 IOSTANDARD LVCMOS33} [get_ports CAM_PWDN]
set_property -dict {PACKAGE_PIN D18 IOSTANDARD LVCMOS33} [get_ports {CAM_D[0]}]
